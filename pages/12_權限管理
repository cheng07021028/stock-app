# -*- coding: utf-8 -*-
from __future__ import annotations

import pandas as pd
import streamlit as st

from auth_manager import (
    MODULES,
    PERMISSION_LEVELS,
    PERM_NONE,
    PERM_READ,
    PERM_WRITE,
    PERM_ADMIN,
    require_module_access,
    render_auth_sidebar,
    render_readonly_banner,
    require_write_permission,
    load_users,
    upsert_user,
    delete_user,
    get_active_sessions_df,
    get_auth_logs_df,
)

st.set_page_config(page_title="12_權限管理", layout="wide")

require_module_access("12", "12_權限管理")
render_auth_sidebar()
render_readonly_banner()

st.title("12 權限管理")
st.caption("管理帳號、模組開啟權限、唯讀 / 可寫權限，並查看目前登入人數與所在模組。")

tab_online, tab_users, tab_logs = st.tabs(["目前登入 / 模組狀態", "帳號與模組權限", "登入與操作紀錄"])


with tab_online:
    st.subheader("目前登入狀態")

    minutes = st.slider("判斷在線時間範圍（分鐘）", min_value=5, max_value=120, value=15, step=5)
    active_df = get_active_sessions_df(minutes=minutes)

    c1, c2, c3 = st.columns(3)
    with c1:
        st.metric("目前在線人數", len(active_df))
    with c2:
        st.metric("目前開啟模組數", active_df["current_module_name"].nunique() if not active_df.empty else 0)
    with c3:
        st.metric("統計範圍", f"{minutes} 分鐘")

    if active_df.empty:
        st.info("目前沒有在線紀錄。")
    else:
        show_cols = [
            "username",
            "display_name",
            "role",
            "current_module_id",
            "current_module_name",
            "login_time",
            "last_seen",
            "session_id",
        ]
        show_cols = [c for c in show_cols if c in active_df.columns]
        st.dataframe(active_df[show_cols], use_container_width=True, hide_index=True)

        st.markdown("#### 模組人數統計")
        module_count = (
            active_df.groupby("current_module_name", dropna=False)
            .size()
            .reset_index(name="登入人數")
            .sort_values("登入人數", ascending=False)
        )
        st.dataframe(module_count, use_container_width=True, hide_index=True)


with tab_users:
    st.subheader("帳號與權限維護")

    users_data = load_users()
    users = users_data.get("users", {})

    user_rows = []
    for username, u in users.items():
        row = {
            "帳號": username,
            "顯示名稱": u.get("display_name", ""),
            "角色": u.get("role", ""),
            "啟用": u.get("active", True),
            "更新時間": u.get("updated_at", ""),
        }
        for mid, mname in MODULES.items():
            row[mname] = u.get("permissions", {}).get(mid, PERM_NONE)
        user_rows.append(row)

    if user_rows:
        st.dataframe(pd.DataFrame(user_rows), use_container_width=True, hide_index=True)
    else:
        st.warning("目前沒有帳號資料。")

    st.markdown("---")
    st.markdown("### 新增 / 修改帳號")

    username_options = ["新增帳號"] + sorted(users.keys())
    selected = st.selectbox("選擇帳號", username_options)

    if selected == "新增帳號":
        default_user = {}
        username_value = ""
        password_help = "新增帳號必填"
    else:
        default_user = users.get(selected, {})
        username_value = selected
        password_help = "留空代表不修改密碼"

    c1, c2, c3, c4 = st.columns([1.4, 1.4, 1.2, 1])
    with c1:
        username = st.text_input("帳號", value=username_value, disabled=(selected != "新增帳號"))
    with c2:
        display_name = st.text_input("顯示名稱", value=default_user.get("display_name", username_value))
    with c3:
        role = st.selectbox(
            "角色",
            ["user", "manager", "admin"],
            index=["user", "manager", "admin"].index(default_user.get("role", "user")) if default_user.get("role", "user") in ["user", "manager", "admin"] else 0,
        )
    with c4:
        active = st.checkbox("啟用", value=default_user.get("active", True))

    password = st.text_input("密碼", type="password", help=password_help)

    st.markdown("#### 模組權限")
    st.caption("無權限：不能開啟；唯讀：可看不可寫；可寫：可新增/刪除/更新；管理員：主要用於權限管理。")

    current_perm = default_user.get("permissions", {})
    new_perm = {}

    module_items = list(MODULES.items())
    for i in range(0, len(module_items), 3):
        cols = st.columns(3)
        for j, (mid, mname) in enumerate(module_items[i:i+3]):
            with cols[j]:
                old_value = current_perm.get(mid, PERM_NONE)
                if role == "admin":
                    default_value = PERM_ADMIN if mid == "12" else PERM_WRITE
                else:
                    default_value = old_value if old_value in PERMISSION_LEVELS else PERM_NONE

                new_perm[mid] = st.selectbox(
                    mname,
                    PERMISSION_LEVELS,
                    index=PERMISSION_LEVELS.index(default_value),
                    key=f"perm_{selected}_{mid}",
                )

    c1, c2, c3 = st.columns([1, 1, 4])
    with c1:
        if st.button("儲存帳號權限", use_container_width=True, type="primary"):
            if require_write_permission("12", "儲存帳號權限"):
                ok, msg = upsert_user(
                    username=username,
                    display_name=display_name,
                    password=password or None,
                    role=role,
                    active=active,
                    permissions=new_perm,
                )
                if ok:
                    st.success(msg)
                    st.rerun()
                else:
                    st.error(msg)

    with c2:
        if selected != "新增帳號":
            if st.button("刪除帳號", use_container_width=True):
                if require_write_permission("12", "刪除帳號"):
                    ok, msg = delete_user(selected)
                    if ok:
                        st.success(msg)
                        st.rerun()
                    else:
                        st.error(msg)


with tab_logs:
    st.subheader("登入與操作紀錄")

    limit = st.slider("顯示最近紀錄筆數", min_value=50, max_value=1000, value=300, step=50)
    logs_df = get_auth_logs_df(limit=limit)

    if logs_df.empty:
        st.info("目前沒有登入或操作紀錄。")
    else:
        st.dataframe(logs_df, use_container_width=True, hide_index=True)

    st.caption("open_module 代表進入模組；write_denied 代表唯讀帳號嘗試寫入被擋；login/logout 代表登入登出。")
